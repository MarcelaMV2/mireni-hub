---
import BadgeDificultad from './BadgeDificultad.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  numero: number;
  titulo: string;
  descripcion: string;
  dificultad?: 'facil' | 'media' | 'dificil';
  etiqueta?: string;
  tags?: string[];
  href: string;
  accion?: string;
  prefijo?: string;
}
const {
  numero, titulo, descripcion, dificultad, etiqueta,
  tags = [], href, accion = 'Ver resolución', prefijo = '',
} = Astro.props;
const nn = prefijo + String(numero).padStart(2, '0');
---

<article
  class="bg-surface border border-default p-6
         transition-all duration-150
         hover:border-primary hover:-translate-x-1 hover:-translate-y-1
         hover:shadow-[6px_6px_0_0_var(--color-primary)]"
>
  <div class="flex items-center gap-3">
    <span class="font-heading text-2xl text-tertiary">{nn}</span>
    {dificultad && <BadgeDificultad nivel={dificultad} />}
    {!dificultad && etiqueta && (
      <span class="font-mono text-xs uppercase tracking-widest border border-default px-2.5 py-1 text-secondary">
        {etiqueta}
      </span>
    )}
  </div>

  <h3 class="text-xl font-semibold mt-3">{titulo}</h3>
  <p class="text-secondary text-[0.95rem] mt-2 max-w-[60ch]">{descripcion}</p>

  <div class="flex items-center justify-between gap-4 mt-6 flex-wrap">
    <div class="flex gap-2 flex-wrap">
      {tags.map((t) => (
        <span class="font-mono text-xs uppercase tracking-widest border border-default px-2.5 py-1 text-secondary">
          {t}
        </span>
      ))}
    </div>

    <a
      href={href}
      class="inline-flex items-center gap-2 bg-primary text-canvas font-mono text-[0.68rem] uppercase tracking-widest px-3.5 py-2.5 whitespace-nowrap transition-colors duration-150 hover:bg-brand"
    >
      {accion}
      <Icon name="tabler:arrow-up-right" width={15} height={15} />
    </a>
  </div>
</article>