---
interface Item {
  texto: string;
  href?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<nav class="flex items-center gap-2 flex-wrap font-mono text-xs uppercase tracking-widest" aria-label="Ruta">
  {items.map((it, i) => (
    <>
      {it.href ? (
        <a href={it.href} class="text-secondary hover:text-primary">{it.texto}</a>
      ) : (
        <span class="text-brand">{it.texto}</span>
      )}
      {i < items.length - 1 && <span class="text-tertiary">›</span>}
    </>
  ))}
</nav>