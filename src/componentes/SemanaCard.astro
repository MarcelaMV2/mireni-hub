---
import { Icon } from 'astro-icon/components';

interface Props {
  numero: number;
  titulo: string;
  resumen: string;
  estado: 'disponible' | 'bloqueada';
  cantidad?: number;
  href?: string;
}
const { numero, titulo, resumen, estado, cantidad = 0, href } = Astro.props;
const bloqueada = estado === 'bloqueada';
const nn = String(numero).padStart(2, '0');

const Tag = bloqueada ? 'div' : 'a';
---

<Tag
  href={bloqueada ? undefined : href}
  class:list={[
    'grid grid-cols-[auto_1fr_auto] md:grid-cols-[auto_1fr_auto] items-center gap-4 py-4 px-2 border-b border-default transition-colors duration-150',
    bloqueada ? 'opacity-50 cursor-not-allowed' : 'hover:bg-canvas',
  ]}
>
  <span class="font-heading text-3xl text-tertiary min-w-[2ch] group-hover:text-brand">
    {nn}
  </span>

  <div class="flex flex-col gap-1">
    <h3 class="font-semibold text-[1.02rem]">Semana {numero} — {titulo}</h3>
    <p class="text-sm text-secondary">{resumen}</p>
  </div>

  <div class="flex items-center justify-end">
    {bloqueada ? (
      <span class="inline-flex items-center gap-2 border border-dashed border-default rounded-md bg-surface px-2.5 py-1.5 font-mono text-xs uppercase tracking-widest text-secondary">
        <Icon name="tabler:lock" width={13} height={13} />
        Coming soon
      </span>
    ) : (
      <span class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-secondary whitespace-nowrap">
        {cantidad} ejercicios
        <Icon name="tabler:arrow-up-right" width={14} height={14} />
      </span>
    )}
  </div>
</Tag>