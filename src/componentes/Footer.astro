---
import { Icon } from 'astro-icon/components';
import { perfil, redes } from '../config/sitio';

interface Props {
  izquierda?: string;
  derecha?: string;
}
const {
  izquierda = `Auxiliatura — ${perfil.gestion}`,
  derecha = 'By Astro',
} = Astro.props;
---

<footer class="border-t border-default mt-16">
  <div class="max-w-[1120px] mx-auto px-4 md:px-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4 py-6">
    <span class="font-mono text-xs uppercase tracking-widest text-secondary" set:html={izquierda} />

    <div class="flex gap-2">
      {redes.map((r) => (
        <a
          href={r.url}
          aria-label={r.nombre}
          target="_blank"
          rel="noopener"
          class="grid place-items-center w-9 h-9 border border-primary rounded-md
                 text-primary transition-all duration-150
                 hover:bg-primary hover:text-canvas hover:-translate-y-0.5"
        >
          <Icon name={r.icono} width={16} height={16} />
        </a>
      ))}
    </div>

    <span class="font-mono text-xs uppercase tracking-widest text-secondary">{derecha}</span>
  </div>
</footer>