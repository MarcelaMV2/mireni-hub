---
import { Icon } from 'astro-icon/components';
import { redes } from '../config/sitio';
---

<div class="flex flex-col gap-3">
  <span class="text-xs uppercase tracking-widest text-secondary">Canales de contacto</span>

  <div class="flex gap-3 flex-wrap">
    {redes.map((r) => (
      <a
        href={r.url}
        aria-label={r.nombre}
        target="_blank"
        rel="noopener"
        class="grid place-items-center w-[52px] h-[52px] border border-primary
               text-primary transition-all duration-150
               hover:bg-primary hover:text-canvas hover:-translate-y-0.5"
      >
        <Icon name={r.icono} width={22} height={22} />
      </a>
    ))}
  </div>
</div>