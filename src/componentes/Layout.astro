---
import "../estilos/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

interface Props {
  titulo: string;
  descripcion?: string;
  /** ítem recuadrado a la derecha del header (ej: "SIS304", "Semana 1") */
  marcaDerecha?: string;
}

const { titulo, descripcion, marcaDerecha } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{titulo}</title>
    {descripcion && <meta name="description" content={descripcion} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header marcaDerecha={marcaDerecha} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
