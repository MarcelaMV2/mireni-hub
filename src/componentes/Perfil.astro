---
import RedesSociales from "./RedesSociales.astro";
import { perfil } from "../config/sitio";
---

<section id="perfil" class="flex flex-col gap-4 pt-12 pb-8">
  <span class="flex items-center gap-3 text-xs uppercase tracking-widest text-secondary">
    <span class="w-7 h-0.5 bg-brand"></span>
    Repositorio de auxiliatura
  </span>

  <div class="flex items-start gap-4">
    <div class="shrink-0 grid place-items-center w-16 h-16 border border-primary font-mono text-xl">
      {perfil.iniciales}
    </div>

    <h1 class="font-heading uppercase tracking-tight leading-[0.9] text-[clamp(2.4rem,9vw,4.6rem)]">
      {perfil.nombre}<br />
      {perfil.apellido.split(" ")[0]}
      <span class="text-brand"> {perfil.apellido.split(" ").slice(1).join(" ")}</span>
    </h1>
  </div>

  <p class="mt-2 text-xs uppercase tracking-widest text-brand">
    {perfil.rol} · {perfil.universidad}
  </p>
  <p class="max-w-[46ch] text-secondary">{perfil.bio}</p>

  <RedesSociales />
</section>